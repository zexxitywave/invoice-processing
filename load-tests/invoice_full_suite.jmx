      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build cold-start token">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import java.util.Base64
long exp  = System.currentTimeMillis() / 1000L + (72 * 3600)
def realIds = [&quot;# 22900&quot;,&quot;# 10365&quot;,&quot;# 26456&quot;,&quot;# 28646&quot;,&quot;# 26455&quot;,&quot;# 22999&quot;,&quot;# 43420&quot;,&quot;# 24443&quot;,&quot;# 30570&quot;,&quot;# 28870&quot;]
def csvId = vars.get(&quot;CSV_INVOICE_ID&quot;)
def invoiceId = (csvId != null &amp;&amp; !csvId.trim().isEmpty()) ? csvId.trim() : realIds[(int)(Math.random() * realIds.size())]
def json  = &quot;&quot;&quot;{&quot;invoiceId&quot;:&quot;${invoiceId}&quot;,&quot;decision&quot;:&quot;APPROVED&quot;,&quot;exp&quot;:${exp}}&quot;&quot;&quot;
def token = Base64.getUrlEncoder().withoutPadding().encodeToString(json.bytes)
vars.put(&quot;COLD_TOKEN&quot;, token)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
