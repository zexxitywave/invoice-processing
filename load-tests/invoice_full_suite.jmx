        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Pick random fileName" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
def files = [
    &quot;invoice_Trudy Brown_17042.pdf&quot;, &quot;vendor_receipt_feb2025.pdf&quot;,
    &quot;aws_bill_march2025.pdf&quot;,     &quot;supplier_inv_Q1.pdf&quot;,
    &quot;tax_invoice_2025.pdf&quot;,       &quot;purchase_order_001.pdf&quot;,
    &quot;monthly_statement.pdf&quot;,      &quot;invoice_zexxity_apr.pdf&quot;
]
vars.put(&quot;UPLOAD_FILE_NAME&quot;, files[(int)(Math.random() * files.size())])
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
