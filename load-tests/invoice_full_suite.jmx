      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build approval tokens" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import java.util.Base64

def csvId     = vars.get(&quot;CSV_INVOICE_ID&quot;)
def invoiceId = (csvId == null || csvId.trim().isEmpty()) ? &quot;LOAD-TOKEN-${ctx.getThreadNum()}&quot; : csvId.trim()
vars.put(&quot;TOKEN_INVOICE_ID&quot;, invoiceId)

long nowSecs = System.currentTimeMillis() / 1000L

// Valid approve token  (exp = now + 72h)
long validExp = nowSecs + (72 * 3600)
def approveJson  = &quot;&quot;&quot;{&quot;invoiceId&quot;:&quot;${invoiceId}&quot;,&quot;decision&quot;:&quot;APPROVED&quot;,&quot;exp&quot;:${validExp}}&quot;&quot;&quot;
def approveToken = Base64.getUrlEncoder().withoutPadding().encodeToString(approveJson.bytes)
vars.put(&quot;VALID_APPROVE_TOKEN&quot;, approveToken)

// Valid reject token  (exp = now + 72h)
def rejectJson   = &quot;&quot;&quot;{&quot;invoiceId&quot;:&quot;${invoiceId}&quot;,&quot;decision&quot;:&quot;REJECTED&quot;,&quot;exp&quot;:${validExp}}&quot;&quot;&quot;
def rejectToken  = Base64.getUrlEncoder().withoutPadding().encodeToString(rejectJson.bytes)
vars.put(&quot;VALID_REJECT_TOKEN&quot;, rejectToken)

// Expired token  (exp = now - 1h)
long expiredExp  = nowSecs - 3600
def expiredJson  = &quot;&quot;&quot;{&quot;invoiceId&quot;:&quot;${invoiceId}&quot;,&quot;decision&quot;:&quot;APPROVED&quot;,&quot;exp&quot;:${expiredExp}}&quot;&quot;&quot;
def expiredToken = Base64.getUrlEncoder().withoutPadding().encodeToString(expiredJson.bytes)
vars.put(&quot;EXPIRED_TOKEN&quot;, expiredToken)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /invoices/approve - Valid Token" enabled="true">
          <stringProp name="HTTPSampler.path">/invoices/approve</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
