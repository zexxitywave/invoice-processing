        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set decision and invoice ID" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
def decision = (Math.random() &lt; 0.6) ? &quot;APPROVED&quot; : &quot;REJECTED&quot;
vars.put(&quot;DECISION&quot;, decision)

def csvId = vars.get(&quot;CSV_INVOICE_ID&quot;)
def realIds = [&quot;# 22900&quot;,&quot;# 10365&quot;,&quot;# 26456&quot;,&quot;# 28646&quot;,&quot;# 26455&quot;,&quot;# 22999&quot;,&quot;# 43420&quot;,&quot;# 24443&quot;,&quot;# 30570&quot;,&quot;# 28870&quot;]
def invoiceId = (csvId != null &amp;&amp; !csvId.trim().isEmpty()) ? csvId.trim() : realIds[(int)(Math.random() * realIds.size())]
vars.put(&quot;TARGET_INVOICE_ID&quot;, invoiceId)

// Build complete JSON body in Groovy to avoid any variable substitution issues
def jsonBody = &quot;{\&quot;invoiceId\&quot;: \&quot;&quot; + invoiceId + &quot;\&quot;, \&quot;decision\&quot;: \&quot;&quot; + decision + &quot;\&quot;, \&quot;reviewer\&quot;: \&quot;loadtest@zexxity.online\&quot;, \&quot;reason\&quot;: \&quot;JMeter load test\&quot;}&quot;
vars.put(&quot;REQUEST_BODY&quot;, jsonBody)
          </stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">false</stringProp>
        </JSR223PreProcessor>
