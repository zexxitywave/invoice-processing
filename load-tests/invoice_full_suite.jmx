        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /invoices/upload-url" enabled="true">
          <stringProp name="HTTPSampler.path">/invoices/upload-url</stringProp>
